# Valores para conectar o CRM à SUA Evolution já existente.
# Copie para deploy/.env (se for rodar por SSH) ou informe estes mesmos valores
# no campo de variáveis de ambiente da Hostinger.

# Endereço da sua Evolution (com https:// e sem barra no final)
EVOLUTION_URL=https://sua-evolution.seusite.com

# Nome da instância que está conectada ao WhatsApp na sua Evolution
EVOLUTION_INSTANCIA=nome-da-sua-instancia

# Chave (API key) da sua Evolution
EVOLUTION_APIKEY=sua-chave-da-evolution

# Endereço que a Evolution usa para avisar o CRM quando chega mensagem.
# Troque SEU_IP_DA_VPS pelo IP da VPS onde este CRM está rodando.
CRM_WEBHOOK_URL=http://SEU_IP_DA_VPS:8765/webhook/evolution
