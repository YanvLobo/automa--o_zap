# Copie para deploy/.env e preencha. NÃO versione o deploy/.env.
#
# ------------------------------- Domínios ---------------------------------
# Aponte estes dois subdomínios (DNS tipo A) para o IP da sua VPS antes de subir.
EVOLUTION_DOMINIO=evolution.virtualmark.com.br
CRM_DOMINIO=crm.virtualmark.com.br

# ------------------------------- Segredos ---------------------------------
# Senha do banco Postgres (invente uma forte).
POSTGRES_PASSWORD=troque-esta-senha-forte

# API key da Evolution (invente uma; será usada pelo CRM e no manager).
EVOLUTION_APIKEY=troque-por-uma-chave-longa-aleatoria

# Nome da instância que você vai criar na Evolution (ex.: virtualzap).
EVOLUTION_INSTANCIA=virtualzap

# Token do webhook (proteção simples; invente um valor).
CRM_WEBHOOK_TOKEN=troque-por-um-token

# ------------------------- Acesso ao painel do CRM ------------------------
# Usuário e senha (em HASH) para abrir o painel. Gere o hash com:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'SUA_SENHA'
CRM_USUARIO=admin
CRM_SENHA_HASH=$2a$14$troque_pelo_hash_gerado_pelo_caddy

# ------------------------------- Chatwoot ---------------------------------
# Opcional. Deixe em branco se não for usar agora.
CHATWOOT_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_KEY=
