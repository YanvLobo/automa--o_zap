# Copie este arquivo para ".env" e ajuste os valores.
# Tudo aqui tem padrão sensato — você só precisa mexer no que for usar.

# ------------------------------ CANAL DE ENVIO ------------------------------
# simulado  = não envia nada, só registra (ideal para testar o funil)
# evolution = Evolution API (único canal com detecção automática de resposta)
# selenium  = WhatsApp Web via VirtualZap.py (só envia, não recebe)
CRM_CANAL=simulado

# ------------------------------ EVOLUTION API -------------------------------
EVOLUTION_URL=https://sua-evolution.seudominio.com
EVOLUTION_INSTANCIA=virtualzap
EVOLUTION_APIKEY=coloque-sua-api-key-aqui
EVOLUTION_VERSAO=v2

# URL PÚBLICA deste CRM, que a Evolution vai chamar quando chegar mensagem.
# Precisa ser acessível pela internet (VPS, ngrok, cloudflared).
CRM_WEBHOOK_URL=https://seu-dominio.com/webhook/evolution
# Opcional: exige o header X-CRM-Token nas chamadas do webhook.
CRM_WEBHOOK_TOKEN=

# --------------------------------- SERVIDOR ---------------------------------
CRM_HOST=127.0.0.1
CRM_PORTA=8765
CRM_BANCO=crm_leads.db

# ---------------------------------- FUNIL -----------------------------------
# De quanto em quanto tempo o worker verifica leads vencidos (segundos).
CRM_WORKER_INTERVALO=60
# LOTE: envia esta quantidade de mensagens e então faz uma pausa automática.
CRM_LOTE_MAXIMO=30
# Pausa automática entre lotes, em minutos (retoma sozinho depois). 0 = sem pausa.
CRM_LOTE_PAUSA_MINUTOS=10
# Pausa entre cada mensagem dentro do lote, em segundos (proteção anti-bloqueio).
CRM_PAUSA_ENTRE_ENVIOS=8
# Janela de horário permitida para disparo (0 e 24 = dia inteiro).
CRM_JANELA_INICIO=8
CRM_JANELA_FIM=20
CRM_FIM_DE_SEMANA=false
# Ligar o funil sozinho quando o servidor subir?
CRM_WORKER_AUTOSTART=false

# --------------------------------- PAINEL -----------------------------------
# Dias sem resposta para o lead aparecer destacado em vermelho.
CRM_ALERTA_DIAS=3
# DDI aplicado a números sem código de país.
CRM_DDI_PADRAO=55

# --------------------------------- CHATWOOT ---------------------------------
# A API Key NUNCA fica no código — vem sempre daqui (variável de ambiente).
CHATWOOT_URL=https://seu-chatwoot.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_API_KEY=coloque-seu-access-token-aqui
# Sincronizar de tempos em tempos (0 = só quando você clicar em "Sincronizar").
CHATWOOT_SYNC_MINUTOS=0
# Itens por página e tentativas em caso de falha de rede.
CHATWOOT_PAGINA=50
CHATWOOT_TENTATIVAS=3
